# --- Mini App: trace log & “devtools” trên WebView (Super App / iPhone) ---
# Copy file này thành `.env` và chỉnh giá trị. Vite chỉ đọc biến bắt đầu bằng VITE_.

# Panel log trong app (addLog) — KHUYẾN NGHỊ cho iPhone: không cần Eruda, không tải CDN.
# Bật = true → build production cũng hiện khung log dưới màn hình (chỉ dùng khi test).
VITE_ENABLE_MINIAPP_LOG_UI=false

# Eruda (console giả trên màn hình). Super App có thể chặn CDN → không hiện được.
# Chỉ bật khi cần xem Network/Elements kiểu DevTools.
VITE_ENABLE_DEVTOOLS=false

# API key NewGen (Thêm thiết bị) — đã có trong .env thật của bạn, không commit secret.
# VITE_NEWGEN_API_KEY=

# ApiKey (header X-Authorization: ApiKey …) cho danh sách thiết bị mẫu GET /api/customer/{customerId}/devices
# VITE_NEWGEN_SAMPLE_DEVICES_API_KEY=

# JWT ThingsBoard (POST …/api/auth/login) — bắt buộc cho WebSocket wss://…/api/ws (ApiKey REST không thay thế được)
# Chỉ dán phần eyJ... hoặc cả dòng "Bearer eyJ..." — hết hạn sẽ lỗi 1011 Invalid JWT
# VITE_NEWGEN_WS_JWT=

# WebSocket subscribe: `true` (mặc định) = `{ "cmds": [...] }` (NewGen). `false` = `tsSubCmds`/`attrSubCmds` (TB UI cũ)
# VITE_NEWGEN_WS_USE_CMDS_FORMAT=true

# Smart Switch 4 kênh — ép nhận diện + POST …/SHARED_SCOPE { "cmd-sw1"|…|"cmd-sw4": "on"|"off" } khi bấm từng nút
# Ví dụ TB: …/DEVICE/2e960fc0-2e4a-11f1-818c-272cb13706a3/SHARED_SCOPE
# VITE_NEWGEN_SMART_SWITCH_DEVICE_IDS=2e960fc0-2e4a-11f1-818c-272cb13706a3

# UUID gateway / đèn hành lang (POST SHARED_SCOPE `cmd-socket`) — thêm vào đây nếu tên TB không chứa "hành lang", v.v.
# Ví dụ: VITE_NEWGEN_GATEWAY_SOCKET_DEVICE_IDS=f4e89f00-21e1-11f1-b9a6-41c05f43cae8
# VITE_NEWGEN_GATEWAY_SOCKET_DEVICE_IDS=

# LED strip — POST `cmd-light` + `cmd-color-temp-light`; WS `state-light`, `color-temp-light`
# Ví dụ: VITE_NEWGEN_LED_STRIP_DEVICE_IDS=9a7458f0-2e9f-11f1-818c-272cb13706a3
# VITE_NEWGEN_LED_STRIP_DEVICE_IDS=

# UUID cảm biến khói / người / cửa (phân tách bằng dấu phẩy) — ép dùng đúng thẻ sensor + subscribe WS
# VITE_NEWGEN_SMOKE_SENSOR_DEVICE_IDS=
# VITE_NEWGEN_HUMAN_SENSOR_DEVICE_IDS=
# VITE_NEWGEN_DOOR_SENSOR_DEVICE_IDS=
# VITE_NEWGEN_FENCE1_SENSOR_DEVICE_IDS=
# VITE_NEWGEN_FENCE2_SENSOR_DEVICE_IDS=
# VITE_NEWGEN_FENCE_SENSOR_DEVICE_IDS=

# --- Endpoints / domain (đưa từ hardcode sang ENV) ---
# Domain deploy chính để quyết định dùng "/api" cùng origin.
VITE_SMARTAPP_HOSTNAME=smartapp-ten.vercel.app

# API base public fallback khi không chạy cùng domain ở trên.
VITE_PUBLIC_API_BASE=https://smartapp-ten.vercel.app/api

# Backend campus mini-app.
VITE_CAMPUS_API_BASE=https://newgen.iot-platform.io.vn/api/v1/mini-app

# NewGen base (ThingsBoard/NewGen).
VITE_NEWGEN_API_BASE=https://newgen.iot-platform.io.vn/api

# CDN devtools (có thể đổi mirror nội bộ nếu Super App chặn CDN mặc định)
VITE_ERUDA_CDN_URL=https://cdn.jsdelivr.net/npm/eruda@3.4.1/eruda.js
VITE_VCONSOLE_CDN_URL=https://unpkg.com/vconsole@3.15.1/dist/vconsole.min.js

# Timeout overlay loading auth (ms). Mặc định 15000.
VITE_AUTH_LOADING_TIMEOUT_MS=15000
